{
  "name": "bitburner",
  "version": "1.0.0",
  "description": "AI that will take over the world in a game called Bitburner",
  "main": "index.js",
  "scripts": {
    "dev": "node scripts/ensure-husky.mjs && viteburner",
    "test": "node scripts/ensure-husky.mjs && vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "yarn oxlint --report-unused-disable-directives",
    "format": "oxfmt --write",
    "format:check": "oxfmt --check",
    "typecheck": "tsgo --noEmit",
    "typecheck:tsc": "tsc --noEmit",
    "setup:hooks": "node scripts/ensure-husky.mjs",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.@(ts|tsx|mts|js|jsx|mjs|cjs)": [
      "oxlint --fix --quiet",
      "oxfmt --write"
    ],
    "*.@(json|jsonc|json5|md|mdx|yaml|yml|css|scss|sass|html|toml)": "oxfmt --write",
    ".github/workflows/*.@(yml|yaml)": "actionlint"
  },
  "devDependencies": {
    "@types/node": "^18.11.18",
    "@typescript/native-preview": "^7.0.0-dev.20260505.1",
    "@vitest/coverage-istanbul": "^3",
    "eslint": "^10.3.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "husky": "9",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "typescript": "^5.4.0",
    "vite": "^6",
    "viteburner": "^0.5.1",
    "vitest": "^3"
  },
  "author": "Webber <webber@takken.io>",
  "license": "MIT",
  "packageManager": "yarn@4.14.1",
  "dependenciesMeta": {
    "esbuild": {
      "built": true
    }
  }
}
