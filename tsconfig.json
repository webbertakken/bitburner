{
  "compilerOptions": {
    "module": "esnext",
    "target": "es2022",
    "lib": ["es2022", "dom"],
    "types": [],
    "strict": true,
    "allowJs": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "noEmit": true,
    "inlineSourceMap": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  // Typecheck only the modules that don't depend on the game-runtime
  // `@ns` types. `NetScriptDefinitions.d.ts` is auto-generated by
  // viteburner when it connects to a live game, so it's not available
  // in CI; running tsc/tsgo over the full tree there would error on
  // every `import { NS } from '@ns'`. The runtime game client typechecks
  // the rest at upload time.
  "include": [
    "src/globals.d.ts",
    "src/contracts/ceasarCypher.ts",
    "src/contracts/tradesMaxProfit.ts",
    "src/core/get.ts",
    "src/core/set.ts",
    "src/config/settings.ts"
  ],
  "exclude": ["node_modules", "dist", "coverage"]
}
